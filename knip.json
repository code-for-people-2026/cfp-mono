{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/website": {
      "entry": [
        "next.config.ts",
        "payload.config.ts",
        "playwright.config.ts",
        "eslint.config.mjs",
        "src/app/**/*.{ts,tsx}",
        "src/content/**/*.ts",
        "src/components/**/*.tsx",
        "src/lib/**/*.ts",
        "src/payload/**/*.ts",
        "tests/**/*.ts"
      ]
    },
    "packages/ui": {
      "entry": ["src/index.ts"]
    },
    "packages/typescript-config": {
      "entry": ["*.json"]
    },
    "packages/eslint-config": {
      "entry": ["index.mjs"]
    },
    "packages/tailwind-config": {
      "entry": ["index.ts"]
    }
  },
  "ignoreDependencies": [
    "@babel/plugin-proposal-decorators",
    "@babel/plugin-transform-class-properties",
    "@tarojs/plugin-framework-react",
    "@tarojs/plugin-platform-h5",
    "@tarojs/plugin-platform-weapp",
    "@tarojs/react",
    "@tarojs/runtime",
    "@tarojs/vite-runner",
    "@types/react-dom",
    "@vitejs/plugin-react",
    "pg",
    "react-dom",
    "serve",
    "vite"
  ],
  "ignoreUnresolved": [
    "next"
  ]
}
