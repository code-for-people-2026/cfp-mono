# 街坊味 v1 backend；复制为 .env 后填写本地值。
KITH_INN_V1_JWT_SECRET=
KITH_INN_V1_INTERNAL_TOKEN=
CMS_BASE_URL=http://localhost:3304
# operator/customer dev login 共用；仅非 production 且显式为 1 时开放。
KITH_INN_V1_ALLOW_DEV_LOGIN=1
# 生产 customer session 必须配置微信 code2Session；weapp 失败不会回退 dev login。
WX_APPID=
WX_SECRET=
BE_PORT=3311
