# kith-inn-cms env — copy to .env and fill real values (.env is gitignored).
#
# payload.config self-loads apps/cms/.env via process.loadEnvFile() at module
# top (before reading DATABASE_URI), so both `pnpm --filter @cfp/cms dev` (next)
# and `pnpm --filter @cfp/cms seed` (tsx) pick these up — tsx doesn't auto-load
# .env like next dev does; the config-level load covers it (commit 524c745).

# Postgres — `pnpm db:up` starts it (docker-compose: host 54324 → 5432, db = cfp):
DATABASE_URI=postgres://postgres:postgres@localhost:54324/cfp

# Payload secret (session / signing):
PAYLOAD_SECRET=

# Shared with apps/kith-inn-be/.env — MUST be equal on both sides (be ↔ cms auth):
JWT_SECRET=
CMS_INTERNAL_TOKEN=
