# kith-inn-cms env — copy to .env and fill real values (.env is gitignored).
#
# payload.config self-loads apps/cms/.env via process.loadEnvFile() at module
# top (before reading the DB url), so both `pnpm --filter @cfp/cms dev` (next)
# and `pnpm --filter @cfp/cms seed` (tsx) pick these up — tsx doesn't auto-load
# .env like next dev does; the config-level load covers it (commit 524c745).

# Postgres — `pnpm db:up` starts it (docker-compose: host 54324 → 5432, db = cfp).
# Use PAYLOAD_DATABASE_URL: payload.config reads it first AND the cms schema-
# isolation test guard (tests/spike-coexistence.test.ts) recognizes it, so the
# test actually runs instead of silently skipping. (payload.config also falls
# back to DATABASE_URL / DATABASE_URI, but the test guard only checks the first
# two — so prefer PAYLOAD_DATABASE_URL here.)
PAYLOAD_DATABASE_URL=postgres://postgres:postgres@localhost:54324/cfp

# Payload secret (session / signing):
PAYLOAD_SECRET=

# Shared with apps/kith-inn-be/.env — MUST be equal on both sides (be ↔ cms auth):
JWT_SECRET=
CMS_INTERNAL_TOKEN=

# 街坊味 v1 独立产品身份；不得复用上面的旧 secret/token。
KITH_INN_V1_JWT_SECRET=
KITH_INN_V1_INTERNAL_TOKEN=
