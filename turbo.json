{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "PAYLOAD_DATABASE_URL",
    "PAYLOAD_SECRET",
    "PAYLOAD_DB_PUSH",
    "ALLOW_ADMIN_BOOTSTRAP",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_MINIAPP_H5_URL",
    "MINIAPP_H5_ORIGIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "@cfp/ui#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
